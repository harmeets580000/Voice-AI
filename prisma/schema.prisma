// AI Receptionist — Phase 1 schema (Scope §5 + doc 03 §1.1.1).
// RULE: every customer-data model carries `organizationId` and is always queried scoped
// by it. Every entity that also lives in Vapi mirrors its Vapi ids + syncStatus locally;
// our DB is the source of truth.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Role {
  super_admin
  org_admin
  org_staff
}

enum OrgStatus {
  trial
  active
  suspended
}

enum BookingStatus {
  pending // new bookings — awaiting manual confirmation; reserves the slot
  confirmed // confirmed by staff (sends the confirmation email); reserves the slot
  booked // legacy synonym of confirmed (rows created before the lifecycle change)
  cancelled
  completed
  no_show
}

enum BookingSource {
  phone
  whatsapp
  web
  admin
}

enum SyncStatus {
  pending
  synced
  failed
  stale
}

enum CallDirection {
  inbound
  outbound
}

enum ReminderChannel {
  sms
  whatsapp
  email
}

enum ReminderStatus {
  pending
  sent
  failed
}

// Product registry — which products (modules) an org has enabled. AI_RECEPTIONIST is the
// base product (implicitly on); OUTBOUND_SALES is opt-in. Values are provider-neutral
// identifiers (UPPER) to match the product catalog; new products append here.
enum ProductKey {
  AI_RECEPTIONIST
  OUTBOUND_SALES
}

enum OrgProductStatus {
  active
  inactive
}

// ---------- Tenancy root ----------

model Organization {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  timezone            String    @default("UTC") // IANA tz, e.g. "America/Los_Angeles"
  dateFormat          String    @default("dd/MM/yyyy HH:mm") // luxon pattern; configurable
  status              OrgStatus @default(trial)
  plan                String?
  logoUrl             String?
  businessHoursConfig Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  users        User[]
  staff        Staff[]
  services     Service[]
  staffServices StaffService[]
  schedules    StaffSchedule[]
  timeOff    StaffTimeOff[]
  customers  Customer[]
  bookings   Booking[]
  calls      Call[]
  messages   CallMessage[]
  documents  Document[]
  kbFiles    KnowledgeBaseFile[]
  vapiTools  VapiTool[]
  reminders  Reminder[]
  syncLogs   SyncLog[]
  vapiConfig OrgVapiConfig?
  theme      OrgTheme?

  // Multi-assistant (1 org : N assistants). Tools/KB/Services/Staff are an org-level library;
  // each assistant selects a subset via the join tables below.
  assistants              Assistant[]
  assistantTools          AssistantTool[]
  assistantKnowledgeFiles AssistantKnowledgeFile[]
  assistantServices       AssistantService[]
  assistantStaff          AssistantStaff[]

  // Product registry (which modules this org has enabled).
  orgProducts OrgProduct[]

  // Outbound Sales (Product 2) — a self-contained module (its own contacts/leads/etc.).
  outboundContacts     OutboundContact[]
  contactImports       ContactImport[]
  contactSegments      ContactSegment[]
  outboundAgents       OutboundAgent[]
  outboundAgentActions OutboundAgentAction[]
  leads                Lead[]
  leadActivities       LeadActivity[]
  leadImports          LeadImport[]
  outboundCalls        OutboundCall[]
  campaigns            Campaign[]
  campaignContacts     CampaignContact[]
  outboundMeetings     OutboundMeeting[]

  @@map("organizations")
}

// ---------- Product registry ----------
// One row per (org, product) that has been explicitly toggled. Absence of a row = default
// (AI_RECEPTIONIST on, OUTBOUND_SALES off). Org-scoped: registered in CUSTOMER_DATA_MODELS.

model OrgProduct {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product        ProductKey
  status         OrgProductStatus @default(inactive)
  enabledAt      DateTime?
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, product])
  @@index([organizationId])
  @@map("org_products")
}

// ---------- Per-org Vapi connection (org-level credential + sync) ----------
// This is the ORG-LEVEL Vapi connection only: the API key, the Vapi org id, the browser
// public key, and connection sync status. All per-assistant data (assistant/phone/KB ids
// + greeting/prompt/voice/llmModel) lives on the `Assistant` model (1 org : N assistants).

model OrgVapiConfig {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  provider  String  @default("vapi") // "vapi" | "retell"
  vapiOrgId String?

  // Optional per-customer Vapi credential override. NULL => use the platform key.
  // Stored ENCRYPTED (AES-256-GCM); plaintext never leaves the server.
  vapiPrivateKeyEnc String?
  vapiKeyLast4      String?

  // Browser-safe Vapi PUBLIC key (NOT secret) — used by the web-call simulator
  // (@vapi-ai/web) to start in-browser voice calls. Stored plain; returned to the client.
  vapiPublicKey String?

  syncStatus   SyncStatus @default(pending)
  lastSyncedAt DateTime?
  syncError    String?

  updatedAt DateTime @updatedAt

  @@map("org_vapi_config")
}

// ---------- Assistants (1 org : N) — provider-neutral mirror + per-assistant config ----------
// Field names are provider-neutral (provider* not vapi*) so Retell/other providers are
// first-class. Our DB stays canonical; provider ids are join keys.

model Assistant {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  isDefault      Boolean      @default(false)

  // Provider mirror ids (per-assistant)
  provider                String  @default("vapi") // "vapi" | "retell" | ...
  providerAssistantId     String? @unique
  providerPhoneNumberId   String? @unique
  providerPhoneNumber     String? @unique // E.164
  providerKnowledgeBaseId String? // composed from this assistant's selected KB files

  // Per-assistant config
  greeting String?
  prompt   String?
  voice    String?
  llmModel String?

  // Sync tracking
  syncStatus   SyncStatus @default(pending)
  lastSyncedAt DateTime?
  syncError    String?
  providerRaw  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Per-assistant selections from the org-level tool / knowledge / service / staff libraries
  tools          AssistantTool[]
  knowledgeFiles AssistantKnowledgeFile[]
  services       AssistantService[]
  staff          AssistantStaff[]
  calls          Call[]

  @@index([organizationId])
  @@index([providerAssistantId])
  @@map("assistants")
}

// Join: which org-library tools an assistant uses (many-to-many).
model AssistantTool {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assistantId    String
  assistant      Assistant    @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  toolId         String
  tool           VapiTool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([assistantId, toolId])
  @@index([organizationId])
  @@index([toolId])
  @@map("assistant_tools")
}

// Join: which org-library knowledge files an assistant uses (many-to-many).
model AssistantKnowledgeFile {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assistantId    String
  assistant      Assistant         @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  fileId         String
  file           KnowledgeBaseFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())

  @@unique([assistantId, fileId])
  @@index([organizationId])
  @@index([fileId])
  @@map("assistant_knowledge_files")
}

// Join: which org-library services an assistant offers (many-to-many).
model AssistantService {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assistantId    String
  assistant      Assistant    @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([assistantId, serviceId])
  @@index([organizationId])
  @@index([serviceId])
  @@map("assistant_services")
}

// Join: which org-library staff an assistant books with (many-to-many).
model AssistantStaff {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assistantId    String
  assistant      Assistant    @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  staffId        String
  staff          Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([assistantId, staffId])
  @@index([organizationId])
  @@index([staffId])
  @@map("assistant_staff")
}

// ---------- Theming ----------

model OrgTheme {
  id              String       @id @default(cuid())
  organizationId  String       @unique
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tokens          Json // stores overrides only; unset values fall back to platform default
  defaultMode     String       @default("light") // "light" | "dark"
  allowUserToggle Boolean      @default(true)
  updatedAt       DateTime     @updatedAt

  @@map("org_theme")
}

// Single-row platform defaults (reserved id "platform").
model PlatformTheme {
  id          String   @id @default("platform")
  tokens      Json
  defaultMode String   @default("light")
  updatedAt   DateTime @updatedAt

  @@map("platform_theme")
}

model PlatformVoiceConfig {
  id                String   @id @default("platform")
  provider          String   @default("vapi")
  vapiPrivateKeyEnc String?
  vapiKeyLast4      String?
  defaultVoice      String?
  defaultLlmModel   String?
  defaultGreeting   String?
  defaultPrompt     String?
  publicApiBaseUrl  String?
  updatedAt         DateTime @updatedAt

  @@map("platform_voice_config")
}

// ---------- Users ----------

model User {
  id             String        @id @default(cuid())
  organizationId String? // null for super_admin
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String        @unique
  name           String?
  passwordHash   String
  role           Role
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  staff Staff[]

  @@index([organizationId])
  @@map("users")
}

// ---------- Staff / services / schedules ----------

model Staff {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  title          String?
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  schedules StaffSchedule[]
  timeOff   StaffTimeOff[]
  bookings  Booking[]

  // Services this staff member can deliver. EMPTY = can deliver ALL (no restriction).
  services StaffService[]

  // Assistants that selected this staff member (per-assistant scoping).
  assistantSelections AssistantStaff[]

  @@index([organizationId])
  @@map("staff")
}

model Service {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  durationMinutes Int
  price           Decimal?     @db.Decimal(10, 2)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())

  bookings Booking[]

  // Staff who can deliver this service (optional binding).
  staff StaffService[]

  // Assistants that selected this service (per-assistant scoping).
  assistantSelections AssistantService[]

  @@index([organizationId])
  @@map("services")
}

/**
 * Optional Staff <-> Service binding (which staff can deliver which service). A staff member with
 * NO rows here can deliver ALL services (no restriction). Used to scope availability by capability.
 */
model StaffService {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staffId        String
  staff          Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([staffId, serviceId])
  @@index([organizationId])
  @@index([serviceId])
  @@map("staff_services")
}

model StaffSchedule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staffId        String
  staff          Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  dayOfWeek      Int // 0=Sunday .. 6=Saturday
  startTime      String // "HH:mm" in org timezone
  endTime        String // "HH:mm" in org timezone

  @@unique([organizationId, staffId, dayOfWeek]) // one schedule per staff per day
  @@index([organizationId])
  @@index([staffId, dayOfWeek])
  @@map("staff_schedules")
}

model StaffTimeOff {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staffId        String
  staff          Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startDatetime  DateTime
  endDatetime    DateTime
  reason         String?

  @@index([organizationId])
  @@index([staffId, startDatetime])
  @@map("staff_time_off")
}

// ---------- Customers / bookings ----------

model Customer {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String?
  phone          String?
  email          String?
  notes          String?
  createdAt      DateTime     @default(now())

  bookings Booking[]
  calls    Call[]

  @@index([organizationId])
  @@index([organizationId, phone])
  @@index([organizationId, createdAt])
  @@map("customers")
}

model Booking {
  id                    String        @id @default(cuid())
  organizationId        String
  organization          Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId            String?
  customer              Customer?     @relation(fields: [customerId], references: [id])
  staffId               String?
  staff                 Staff?        @relation(fields: [staffId], references: [id])
  serviceId             String?
  service               Service?      @relation(fields: [serviceId], references: [id])
  startDatetime         DateTime
  endDatetime           DateTime
  status                BookingStatus @default(pending)
  source                BookingSource @default(phone)
  paymentStatus         String? // future (Phase 4)
  googleCalendarEventId String?
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([organizationId])
  @@index([organizationId, startDatetime])
  @@index([staffId, startDatetime])
  @@map("bookings")
}

// ---------- Calls / transcripts ----------

model Call {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])
  // Which assistant handled the call (multi-assistant). Nullable for legacy rows.
  assistantId    String?
  assistant      Assistant?    @relation(fields: [assistantId], references: [id])
  direction      CallDirection @default(inbound)

  vapiCallId          String    @unique
  vapiOrgId           String?
  vapiAssistantId     String?
  vapiPhoneNumberId   String?
  phoneCallProvider   String?
  phoneCallProviderId String?
  fromNumber          String?
  toNumber            String?
  endedReason         String?
  cost                Decimal?  @db.Decimal(10, 4)
  costBreakdown       Json?
  recordingUrl        String?
  summary             String?
  startedAt           DateTime?
  endedAt             DateTime?
  durationSeconds     Int?
  vapiRaw             Json? // full raw provider call payload (all data for the call)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  messages CallMessage[]

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([assistantId])
  @@map("calls")
}

model CallMessage {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  callId           String
  call             Call         @relation(fields: [callId], references: [id], onDelete: Cascade)
  role             String // "assistant" | "user" | "system" | "tool"
  text             String
  secondsFromStart Float?
  createdAt        DateTime     @default(now())

  @@index([organizationId])
  @@index([callId])
  @@map("call_messages")
}

// ---------- Voice tools mirror ----------

model VapiTool {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vapiToolId     String?      @unique
  name           String // built-ins: check_availability | book_appointment | lookup_customer
  kind           String       @default("builtin") // "builtin" | "custom"
  enabled        Boolean      @default(true) // only enabled tools are pushed to Vapi
  description    String? // shown to the assistant; editable for custom tools
  parameters     Json? // JSON-schema-ish parameter spec for custom function tools
  serverUrl      String? // built-ins use our webhook; custom tools use a user-supplied URL
  staticParams   Json? // includes our organization_id
  provider       String       @default("vapi")
  syncStatus     SyncStatus   @default(pending)
  lastSyncedAt   DateTime?
  syncError      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Assistants that selected this org-library tool.
  assistantSelections AssistantTool[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("vapi_tools")
}

// ---------- Sync history (audit of every Vapi sync run) ----------

model SyncLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String // "provision" | "resync" | "tools_sync"
  status         String // "success" | "partial" | "failed"
  summary        String? // one-line human summary
  details        Json? // full detail: counts, per-step results, ids touched
  error          String? // error message when status = failed
  triggeredBy    String? // userId that initiated the run (null = system)
  startedAt      DateTime     @default(now())
  finishedAt     DateTime?

  @@index([organizationId, startedAt])
  @@map("sync_logs")
}

// ---------- Knowledge ----------

model Document {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  storagePath    String
  mimeType       String?
  sizeBytes      Int?
  uploadedAt     DateTime     @default(now())

  kbFiles KnowledgeBaseFile[]

  @@index([organizationId])
  @@map("documents")
}

model KnowledgeBaseFile {
  id                  String       @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentId          String
  document            Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  vapiFileId          String?      @unique
  vapiKnowledgeBaseId String?
  sizeBytes           Int?
  syncStatus          SyncStatus   @default(pending)
  lastSyncedAt        DateTime?
  syncError           String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // Assistants that selected this org-library knowledge file.
  assistantSelections AssistantKnowledgeFile[]

  @@index([organizationId])
  @@index([documentId])
  @@map("knowledge_base_files")
}

// ---------- Reminders (Phase 3 wiring; table exists in Phase 1) ----------

model Reminder {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookingId      String
  channel        ReminderChannel
  scheduledFor   DateTime
  status         ReminderStatus  @default(pending)
  sentAt         DateTime?
  createdAt      DateTime        @default(now())

  @@index([organizationId])
  @@index([status, scheduledFor])
  @@map("reminders")
}

// ============================================================
// Outbound Sales & Lead Gen (Product 2)
// A self-contained module: shares only Organization/User/Role with Inbound. Every model
// below is org-scoped (registered in CUSTOMER_DATA_MODELS) and independent of the inbound
// Customer/Call/Booking tables (by design — see the build plan).
// ============================================================

// The sales "Contacts" — the audience for campaigns/leads. optOut/DNC + tags/source/custom
// fields live here (not on the inbound Customer). Deduped by phone/email within an org.
model OutboundContact {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String?
  phone          String?
  email          String?
  notes          String?
  optOut         Boolean      @default(false)
  optOutReason   String?
  tags           String[]     @default([])
  source         String? // origin tag: IMPORT | MANUAL | PROMOTED | ...
  customFields   Json? // arbitrary imported columns
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  leads         Lead[]
  outboundCalls OutboundCall[]

  @@index([organizationId])
  @@index([organizationId, phone])
  @@index([organizationId, email])
  @@map("outbound_contacts")
}

// Audit of a CSV contact import run (column map + counts + errors).
model ContactImport {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  filename       String
  mappingJson    Json?
  totalRows      Int          @default(0)
  importedRows   Int          @default(0)
  skippedRows    Int          @default(0)
  errorsJson     Json?
  status         String       @default("COMPLETED") // PENDING|VALIDATED|COMPLETED|FAILED
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@map("contact_imports")
}

// A saved, reusable audience filter over OutboundContacts.
model ContactSegment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  filterJson     Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@map("contact_segments")
}

enum OutboundAgentStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

// Config-only this phase. The editor persists these; NOTHING executes until the MAF runtime.
enum OutboundActionType {
  QUALIFY_LEAD
  BOOK_MEETING
  CAPTURE_CONTACT
  SEND_FOLLOWUP
  MARK_DNC
  ANSWER_KB
}

// A sales script/persona for VOICE campaigns + one-off calls. Multiple per org (unlike the
// Receptionist's one/org). providerAssistantId is reserved for the future runtime.
model OutboundAgent {
  id                  String              @id @default(cuid())
  organizationId      String
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                String
  language            String              @default("en-US")
  voiceId             String?
  persona             String?
  openingLine         String?
  systemPrompt        String?
  goalsJson           Json?
  behaviorJson        Json?
  status              OutboundAgentStatus @default(DRAFT)
  providerAssistantId String? // future runtime
  // From-number for outbound calls/campaigns — the org's Vapi number (pulled live via the port).
  providerPhoneNumber   String? // E.164
  providerPhoneNumberId String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  actions OutboundAgentAction[]

  @@index([organizationId])
  @@map("outbound_agents")
}

// Config-only agent actions. Enabling + editing configJson persists intent; nothing runs
// (e.g. MARK_DNC does NOT set OutboundContact.optOut this phase).
model OutboundAgentAction {
  id              String             @id @default(cuid())
  outboundAgentId String
  outboundAgent   OutboundAgent      @relation(fields: [outboundAgentId], references: [id], onDelete: Cascade)
  organizationId  String // denormalized for scoping; NOT the sole tenant guard
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type            OutboundActionType
  enabled         Boolean            @default(false)
  configJson      Json?
  order           Int                @default(0)

  @@unique([outboundAgentId, type])
  @@index([organizationId])
  @@map("outbound_agent_actions")
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum LeadSource {
  OUTBOUND_CALL
  CAMPAIGN
  INBOUND_CALL
  MANUAL
  IMPORT
}

// A promoted/entered OutboundContact worked through the sales pipeline.
model Lead {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId      String
  contact        OutboundContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  stage          LeadStage       @default(NEW)
  source         LeadSource
  ownerUserId    String? // assigned rep (a User)
  value          Decimal?        @db.Decimal(12, 2)
  campaignId     String?
  callId         String? // originating OutboundCall
  leadImportId   String? // if created via CSV (Q3.5)
  lostReason     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  activities LeadActivity[]

  @@index([organizationId, stage])
  @@index([organizationId, contactId])
  @@map("leads")
}

// Append-only timeline: CREATED | STAGE_CHANGED | NOTE | ASSIGNED | CALL | CONVERTED.
model LeadActivity {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type           String
  dataJson       Json?
  userId         String?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([leadId])
  @@map("lead_activities")
}

// Audit of a CSV lead-import run. Each row upserts a Contact first, then creates a Lead.
model LeadImport {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  filename       String
  mappingJson    Json?
  totalRows      Int          @default(0)
  importedRows   Int          @default(0)
  skippedRows    Int          @default(0)
  errorsJson     Json?
  status         String       @default("COMPLETED") // PENDING|VALIDATED|COMPLETED|FAILED
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@map("lead_imports")
}

enum OutboundCallStatus {
  QUEUED
  RINGING
  COMPLETED
  FAILED
  CANCELLED
}

// The outbound module's OWN call log (separate from the inbound, Vapi-mirrored Call). This
// phase they are QUEUED stubs — no real dial. Generated by one-off calls (§E) + campaigns (§D).
model OutboundCall {
  id                String             @id @default(cuid())
  organizationId    String
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId         String?
  contact           OutboundContact?   @relation(fields: [contactId], references: [id])
  leadId            String?
  campaignId        String?
  outboundAgentId   String?
  status            OutboundCallStatus @default(QUEUED)
  fromNumber        String?
  toNumber          String?
  initiatedByUserId String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("outbound_calls")
}

// Only VOICE is launchable this phase; SMS/WHATSAPP/EMAIL are reserved seams (present so the
// messaging path returns without a migration) — rejected in UI + server.
enum CampaignChannel {
  VOICE
  SMS
  WHATSAPP
  EMAIL
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

// A voice campaign over a segment/ad-hoc audience. Launch (stub) generates QUEUED OutboundCalls.
model Campaign {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  channel         CampaignChannel @default(VOICE)
  outboundAgentId String? // required for VOICE launch
  templateId      String? // RESERVED (messaging, future)
  segmentId       String? // audience source
  audienceJson    Json? // resolved/ad-hoc audience filter
  pacingPerHour   Int             @default(60)
  quietHoursJson  Json?
  status          CampaignStatus  @default(DRAFT)
  statsJson       Json? // {total,queued,skipped}
  scheduledAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  members CampaignContact[]

  @@index([organizationId])
  @@map("campaigns")
}

model CampaignContact {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaignId     String
  campaign       Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId      String
  status         String       @default("PENDING") // PENDING|QUEUED|DONE|SKIPPED
  outboundCallId String? // VOICE → stub OutboundCall
  messageId      String? // RESERVED (messaging, future)

  @@unique([campaignId, contactId])
  @@index([organizationId])
  @@map("campaign_contacts")
}

enum OutboundMeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// The outbound module's OWN minimal scheduler: a meeting between a lead's contact and an owner
// rep (a User). Double-booking of the rep is guarded in meeting.engine.ts.
model OutboundMeeting {
  id             String                @id @default(cuid())
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String
  contactId      String
  ownerUserId    String
  startDatetime  DateTime
  endDatetime    DateTime
  status         OutboundMeetingStatus @default(SCHEDULED)
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([organizationId, ownerUserId, startDatetime])
  @@map("outbound_meetings")
}
